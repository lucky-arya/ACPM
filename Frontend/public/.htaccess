<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let existing files/directories resolve normally.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Send all other requests to the SPA entry point.
  RewriteRule ^ index.html [L]
</IfModule>
